generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id       String   @id @default(uuid())
  nome     String
  email    String   @unique
  senha    String?
  googleId String?  @unique
  criadoEm DateTime @default(now())

  plano          Plano   @default(FREE) // Novo campo para plano
  premiumExpiraEm DateTime? // Data em que o plano premium deixa de valer
  exibirAnuncios Boolean @default(true) // Se usuário Free exibe anúncios

  role Role @default(USER)

  resetToken    String?
  resetTokenExp DateTime?

  receitas Receita[]
  despesas Despesa[]

  categorias Categoria[]

  pagamentosPremium PagamentoPremium[]
  cartoesCredito CartaoCredito[]
}

model PagamentoPremium {
  id                         String          @id @default(uuid())
  usuarioId                  String
  usuario                    Usuario         @relation(fields: [usuarioId], references: [id])
  mercadoPagoPreferenceId    String?         @unique
  mercadoPagoPaymentId       String?         @unique
  externalReference          String          @unique
  status                     PagamentoStatus @default(PENDING)
  valor                      Decimal         @db.Decimal(10, 2)
  checkoutUrl                String?
  criadoEm                   DateTime        @default(now())
  atualizadoEm               DateTime        @updatedAt
}

model Receita {
  id        String   @id @default(uuid())
  descricao String
  valor     Decimal  @db.Decimal(10, 2)
  data      DateTime
  fixa      Boolean  @default(false)
  numeroParcelas Int?
  parcelaAtual   Int?
  parcelamentoId String?
  criadoEm  DateTime @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])
}

model Despesa {
  id             String    @id @default(uuid())
  descricao      String
  valor          Decimal   @db.Decimal(10, 2)
  categoriaNome  String?
  formaPagamento FormaPagamentoDespesa @default(DINHEIRO)
  cartaoCreditoId String?
  cartaoCredito   CartaoCredito? @relation(fields: [cartaoCreditoId], references: [id], onDelete: SetNull)
  mesReferencia  DateTime  @default(now())
  dataVencimento DateTime?
  dataPagamento  DateTime?
  paga           Boolean   @default(false)
  fixa           Boolean   @default(false)
  numeroParcelas Int?
  parcelaAtual   Int?
  parcelamentoId String?
  criadoEm       DateTime  @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])
}

model CartaoCredito {
  id       String   @id @default(uuid())
  nome     String
  criadoEm DateTime @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  despesas Despesa[]

  @@unique([usuarioId, nome])
}

model Categoria {
  id       String        @id @default(uuid())
  nome     String
  tipo     TipoCategoria
  criadoEm DateTime      @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  receitas Receita[]
  despesas Despesa[]
}

enum TipoCategoria {
  RECEITA
  DESPESA
}

enum Role {
  ADMIN
  USER
}

enum Plano {
  FREE
  PREMIUM
}

enum PagamentoStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
}

enum FormaPagamentoDespesa {
  DINHEIRO
  CARTAO_CREDITO
  DIVIDA
}
