generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                          String                      @id @default(uuid())
  nome                        String
  email                       String                      @unique
  senha                       String?
  googleId                    String?                     @unique
  criadoEm                    DateTime                    @default(now())
  plano                       Plano                       @default(FREE)
  premiumExpiraEm             DateTime?
  exibirAnuncios              Boolean                     @default(true)
  role                        Role                        @default(USER)
  resetToken                  String?
  resetTokenExp               DateTime?
  cartoesCredito              CartaoCredito[]
  categorias                  Categoria[]
  despesas                    Despesa[]
  despesasExcecoesRecorrencia DespesaExcecaoRecorrencia[]
  pagamentosPremium           PagamentoPremium[]
  perfisFinanceiros           PerfilFinanceiro[]
  receitas                    Receita[]
  receitasExcecoesRecorrencia ReceitaExcecaoRecorrencia[]
  sessoes                     SessaoUsuario[]
  sugestoes                   Sugestao[]
  pushTokens                  PushToken[]
}

model SessaoUsuario {
  id           String   @id @default(uuid())
  usuarioId    String
  criadaEm     DateTime @default(now())
  atualizadaEm DateTime @updatedAt
  expiraEm     DateTime
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([atualizadaEm])
  @@index([expiraEm])
}

model PerfilFinanceiro {
  id             String          @id @default(uuid())
  nome           String
  avatar         String          @default("user")
  tema           String          @default("system")
  criadoEm       DateTime        @default(now())
  atualizadoEm   DateTime        @updatedAt
  usuarioId      String
  cartoesCredito CartaoCredito[]
  despesas       Despesa[]
  usuario        Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  receitas       Receita[]

  @@unique([usuarioId, nome])
  @@index([usuarioId, criadoEm])
}

model PagamentoPremium {
  id                       String          @id @default(uuid())
  usuarioId                String
  mercadoPagoPreferenceId  String?         @unique
  mercadoPagoPreapprovalId String?         @unique
  mercadoPagoPaymentId     String?         @unique
  externalReference        String          @unique
  tipo                     PagamentoTipo   @default(CHECKOUT)
  status                   PagamentoStatus @default(PENDING)
  assinaturaStatus         String?
  valor                    Decimal         @db.Decimal(10, 2)
  checkoutUrl              String?
  canceladoEm              DateTime?
  criadoEm                 DateTime        @default(now())
  atualizadoEm             DateTime        @updatedAt
  usuario                  Usuario         @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, criadoEm])
  @@index([status, criadoEm])
  @@index([tipo, status])
}

model Receita {
  id                   String                      @id @default(uuid())
  descricao            String
  valor                Decimal                     @db.Decimal(10, 2)
  data                 DateTime
  fixa                 Boolean                     @default(false)
  recorrenciaFim       DateTime?
  recorrenciaEncerrada Boolean                     @default(false)
  numeroParcelas       Int?
  parcelaAtual         Int?
  parcelamentoId       String?
  criadoEm             DateTime                    @default(now())
  usuarioId            String
  perfilFinanceiroId   String?
  categoriaId          String?
  categoria            Categoria?                  @relation(fields: [categoriaId], references: [id])
  perfilFinanceiro     PerfilFinanceiro?           @relation(fields: [perfilFinanceiroId], references: [id], onDelete: Cascade)
  usuario              Usuario                     @relation(fields: [usuarioId], references: [id])
  excecoesRecorrencia  ReceitaExcecaoRecorrencia[]

  @@index([usuarioId, perfilFinanceiroId, data])
  @@index([usuarioId, perfilFinanceiroId, fixa, data])
  @@index([parcelamentoId, usuarioId])
}

model ReceitaExcecaoRecorrencia {
  id            String   @id @default(uuid())
  usuarioId     String
  receitaId     String
  mesReferencia DateTime
  criadoEm      DateTime @default(now())
  receita       Receita  @relation(fields: [receitaId], references: [id], onDelete: Cascade)
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([receitaId, usuarioId, mesReferencia])
  @@index([usuarioId, mesReferencia])
}

model Despesa {
  id                   String                      @id @default(uuid())
  descricao            String
  valor                Decimal                     @db.Decimal(10, 2)
  categoriaNome        String?
  formaPagamento       FormaPagamentoDespesa       @default(DINHEIRO)
  cartaoCreditoId      String?
  mesReferencia        DateTime                    @default(now())
  dataVencimento       DateTime?
  dataPagamento        DateTime?
  paga                 Boolean                     @default(false)
  fixa                 Boolean                     @default(false)
  recorrenciaFim       DateTime?
  recorrenciaEncerrada Boolean                     @default(false)
  numeroParcelas       Int?
  parcelaAtual         Int?
  parcelamentoId       String?
  criadoEm             DateTime                    @default(now())
  usuarioId            String
  perfilFinanceiroId   String?
  categoriaId          String?
  cartaoCredito        CartaoCredito?              @relation(fields: [cartaoCreditoId], references: [id])
  categoria            Categoria?                  @relation(fields: [categoriaId], references: [id])
  perfilFinanceiro     PerfilFinanceiro?           @relation(fields: [perfilFinanceiroId], references: [id], onDelete: Cascade)
  usuario              Usuario                     @relation(fields: [usuarioId], references: [id])
  excecoesRecorrencia  DespesaExcecaoRecorrencia[]

  @@index([usuarioId, perfilFinanceiroId, mesReferencia])
  @@index([usuarioId, perfilFinanceiroId, fixa, mesReferencia])
  @@index([usuarioId, perfilFinanceiroId, paga, dataVencimento])
  @@index([cartaoCreditoId, usuarioId])
  @@index([parcelamentoId, usuarioId])
}

model DespesaExcecaoRecorrencia {
  id            String   @id @default(uuid())
  usuarioId     String
  despesaId     String
  mesReferencia DateTime
  criadoEm      DateTime @default(now())
  despesa       Despesa  @relation(fields: [despesaId], references: [id], onDelete: Cascade)
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([despesaId, usuarioId, mesReferencia])
  @@index([usuarioId, mesReferencia])
}

model CartaoCredito {
  id                 String            @id @default(uuid())
  nome               String
  criadoEm           DateTime          @default(now())
  deletedAt          DateTime?
  usuarioId          String
  perfilFinanceiroId String?
  perfilFinanceiro   PerfilFinanceiro? @relation(fields: [perfilFinanceiroId], references: [id], onDelete: Cascade)
  usuario            Usuario           @relation(fields: [usuarioId], references: [id])
  despesas           Despesa[]

  @@index([usuarioId, perfilFinanceiroId, deletedAt])
}

model Sugestao {
  id        String       @id @default(uuid())
  tipo      SugestaoTipo
  titulo    String
  mensagem  String
  status    String       @default("ABERTO")
  criadoEm  DateTime     @default(now())
  usuarioId String
  usuario   Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, criadoEm])
  @@index([tipo, criadoEm])
}

model Categoria {
  id        String        @id @default(uuid())
  nome      String
  tipo      TipoCategoria
  criadoEm  DateTime      @default(now())
  usuarioId String
  usuario   Usuario       @relation(fields: [usuarioId], references: [id])
  despesas  Despesa[]
  receitas  Receita[]
}

enum TipoCategoria {
  RECEITA
  DESPESA
}

enum Role {
  ADMIN
  USER
}

enum Plano {
  FREE
  PREMIUM
}

enum PagamentoStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
}

enum PagamentoTipo {
  CHECKOUT
  ASSINATURA
}

enum FormaPagamentoDespesa {
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  VALE_ALIMENTACAO
  VALE_REFEICAO
  BOLETO
}

enum SugestaoTipo {
  RECLAMACAO
  ELOGIO
  SUGESTAO
  OUTRO
}

model PushToken {
  id           String   @id @default(uuid())
  usuarioId    String
  token        String   @unique
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}
