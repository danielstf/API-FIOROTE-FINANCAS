generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id       String   @id @default(uuid())
  nome     String
  email    String   @unique
  senha    String?
  googleId String?  @unique
  criadoEm DateTime @default(now())

  plano          Plano   @default(FREE) // Novo campo para plano
  premiumExpiraEm DateTime? // Data em que o plano premium deixa de valer
  exibirAnuncios Boolean @default(true) // Se usuário Free exibe anúncios

  role Role @default(USER)

  resetToken    String?
  resetTokenExp DateTime?

  receitas Receita[]
  despesas Despesa[]
  receitasExcecoesRecorrencia ReceitaExcecaoRecorrencia[]

  categorias Categoria[]

  pagamentosPremium PagamentoPremium[]
  cartoesCredito CartaoCredito[]
  despesasExcecoesRecorrencia DespesaExcecaoRecorrencia[]
  sugestoes Sugestao[]
  perfisFinanceiros PerfilFinanceiro[]
  sessoes SessaoUsuario[]
}

model SessaoUsuario {
  id         String   @id @default(uuid())
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  criadaEm   DateTime @default(now())
  atualizadaEm DateTime @updatedAt
  expiraEm   DateTime

  @@index([usuarioId])
  @@index([atualizadaEm])
  @@index([expiraEm])
}


model PerfilFinanceiro {
  id        String   @id @default(uuid())
  nome      String
  avatar    String   @default("user")
  tema      String   @default("system")
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  receitas Receita[]
  despesas Despesa[]
  cartoesCredito CartaoCredito[]

  @@unique([usuarioId, nome])
  @@index([usuarioId, criadoEm])
}
model PagamentoPremium {
  id                         String          @id @default(uuid())
  usuarioId                  String
  usuario                    Usuario         @relation(fields: [usuarioId], references: [id])
  mercadoPagoPreferenceId    String?         @unique
  mercadoPagoPaymentId       String?         @unique
  externalReference          String          @unique
  status                     PagamentoStatus @default(PENDING)
  valor                      Decimal         @db.Decimal(10, 2)
  checkoutUrl                String?
  criadoEm                   DateTime        @default(now())
  atualizadoEm               DateTime        @updatedAt
}

model Receita {
  id        String   @id @default(uuid())
  descricao String
  valor     Decimal  @db.Decimal(10, 2)
  data      DateTime
  fixa      Boolean  @default(false)
  recorrenciaFim DateTime?
  numeroParcelas Int?
  parcelaAtual   Int?
  parcelamentoId String?
  criadoEm  DateTime @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  perfilFinanceiroId String?
  perfilFinanceiro   PerfilFinanceiro? @relation(fields: [perfilFinanceiroId], references: [id], onDelete: Cascade)

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])

  excecoesRecorrencia ReceitaExcecaoRecorrencia[]
}

model ReceitaExcecaoRecorrencia {
  id            String   @id @default(uuid())
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  receitaId     String
  receita       Receita  @relation(fields: [receitaId], references: [id], onDelete: Cascade)
  mesReferencia DateTime
  criadoEm      DateTime @default(now())

  @@unique([receitaId, usuarioId, mesReferencia])
  @@index([usuarioId, mesReferencia])
}

model Despesa {
  id             String    @id @default(uuid())
  descricao      String
  valor          Decimal   @db.Decimal(10, 2)
  categoriaNome  String?
  formaPagamento FormaPagamentoDespesa @default(DINHEIRO)
  cartaoCreditoId String?
  cartaoCredito   CartaoCredito? @relation(fields: [cartaoCreditoId], references: [id], onDelete: SetNull)
  mesReferencia  DateTime  @default(now())
  dataVencimento DateTime?
  dataPagamento  DateTime?
  paga           Boolean   @default(false)
  fixa           Boolean   @default(false)
  recorrenciaFim DateTime?
  numeroParcelas Int?
  parcelaAtual   Int?
  parcelamentoId String?
  criadoEm       DateTime  @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  perfilFinanceiroId String?
  perfilFinanceiro   PerfilFinanceiro? @relation(fields: [perfilFinanceiroId], references: [id], onDelete: Cascade)

  categoriaId String?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])

  excecoesRecorrencia DespesaExcecaoRecorrencia[]
}

model DespesaExcecaoRecorrencia {
  id            String   @id @default(uuid())
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  despesaId     String
  despesa       Despesa  @relation(fields: [despesaId], references: [id], onDelete: Cascade)
  mesReferencia DateTime
  criadoEm      DateTime @default(now())

  @@unique([despesaId, usuarioId, mesReferencia])
  @@index([usuarioId, mesReferencia])
}

model CartaoCredito {
  id       String   @id @default(uuid())
  nome     String
  criadoEm DateTime @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  perfilFinanceiroId String?
  perfilFinanceiro   PerfilFinanceiro? @relation(fields: [perfilFinanceiroId], references: [id], onDelete: Cascade)

  despesas Despesa[]

  @@unique([usuarioId, nome, perfilFinanceiroId])
  @@index([usuarioId, perfilFinanceiroId])
}


model Sugestao {
  id        String       @id @default(uuid())
  tipo      SugestaoTipo
  titulo    String
  mensagem  String
  status    String       @default("ABERTO")
  criadoEm  DateTime     @default(now())

  usuarioId String
  usuario   Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, criadoEm])
  @@index([tipo, criadoEm])
}
model Categoria {
  id       String        @id @default(uuid())
  nome     String
  tipo     TipoCategoria
  criadoEm DateTime      @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  receitas Receita[]
  despesas Despesa[]
}

enum TipoCategoria {
  RECEITA
  DESPESA
}

enum Role {
  ADMIN
  USER
}

enum Plano {
  FREE
  PREMIUM
}

enum PagamentoStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
}

enum FormaPagamentoDespesa {
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  VALE_ALIMENTACAO
  VALE_REFEICAO
  BOLETO
}

enum SugestaoTipo {
  RECLAMACAO
  ELOGIO
  SUGESTAO
  OUTRO
}
